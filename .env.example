# asyagent Configuration
# Copy to .env and edit as needed

# --- Server ---
ASYAGENT_HOST=0.0.0.0
ASYAGENT_PORT=8787
ASYAGENT_MAX_WORKERS=16
ASYAGENT_COMPILE_TIMEOUT=60
ASYAGENT_MAX_TIMEOUT=300
ASYAGENT_FETCH_TIMEOUT=20
ASYAGENT_MAX_SOURCE_BYTES=1048576
ASYAGENT_MAX_FETCH_BYTES=5242880
ASYAGENT_ASY_BIN=asy
ASYAGENT_GS_BIN=gs
ASYAGENT_DEFAULT_FORMAT=pdf
ASYAGENT_DEFAULT_MODE=inline
ASYAGENT_DEFAULT_ENCODING=binary
ASYAGENT_DEFAULT_DPI=150
# ASYAGENT_TMP_DIR=/tmp/asyagent

# --- Storage backend: local | s3 | none ---
ASYAGENT_STORAGE=local
ASYAGENT_LOCAL_DIR=./storage
# ASYAGENT_LOCAL_BASE_URL=http://example.com:8787

# --- S3 / Object Storage (set ASYAGENT_STORAGE=s3) ---
# S3_BUCKET=my-bucket
S3_PREFIX=asyagent/
# S3_ENDPOINT=http://minio:9000
S3_URL_STYLE=path
# S3_PUBLIC_BASE_URL=https://cdn.example.com
S3_PRESIGN=false
S3_PRESIGN_EXPIRES=3600
S3_USE_TLS=true
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
